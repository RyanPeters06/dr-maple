rules_version = '2';
// IMPORTANT: Deploy these rules or profile (and other data) will fail with "Missing or insufficient permissions".
// Option A — Firebase Console: Firestore Database → Rules → paste this entire file → Publish.
// Option B — CLI: npm i -g firebase-tools && firebase login && firebase use <your-project-id> && firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{sessionId} {
      allow read, write: if true;
    }
    match /pairingCodes/{code} {
      allow read, write: if true;
    }
    match /users/{userId}/{document=**} {
      allow read, write: if true;
    }
    match /userProfiles/{userId} {
      allow read, write: if true;
    }
  }
}
